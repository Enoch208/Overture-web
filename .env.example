# ── Models ────────────────────────────────────────────────────────────────────
# LiteLLM model strings — one per agent. Defaults to Gemini 2.5 Flash.
ORCHESTRATOR_MODEL=gemini/gemini-2.5-flash
PHARMACY_MODEL=gemini/gemini-2.5-flash
HOME_HEALTH_MODEL=gemini/gemini-2.5-flash

# Google AI Studio key (https://aistudio.google.com/apikey)
GOOGLE_API_KEY=
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# ── Public URLs ───────────────────────────────────────────────────────────────
# When deployed, set each to the Cloud Run URL. Locally, leave the defaults.
ORCHESTRATOR_URL=http://localhost:8080
PHARMACY_URL=http://localhost:8082
HOME_HEALTH_URL=http://localhost:8083
CAREPLAN_MCP_URL=http://localhost:8081

# ── Prompt Opinion platform ───────────────────────────────────────────────────
# Sets the FHIR-context extension URI advertised in the agent card.
PO_PLATFORM_BASE_URL=https://app.promptopinion.ai

# ── API keys ──────────────────────────────────────────────────────────────────
# Generated per agent. Paste these into PO when registering each external agent.
ORCHESTRATOR_API_KEY=replace-me-orchestrator
PHARMACY_API_KEY=replace-me-pharmacy
HOME_HEALTH_API_KEY=replace-me-home-health

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_HOOK_RAW_OBJECTS=false
